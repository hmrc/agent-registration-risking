# IF THE MICRO-SERVICE DOES NOT NEED ANY TEST-ONLY END-POINTS (ALWAYS PREFERRED) DELETE THIS FILE.

# !!!WARNING!!! This file MUST NOT be referenced in the "application.conf" file to avoid risk of rolling test routes in the production environment.
# If you need test routes when running tests in CI make sure that the profile for this micro-service (used by service-manager) defines this router as parameter.
# To do so add the following line to the micro-service profile: "-Dapplication.router=testOnlyDoNotUseInAppConf.Routes"
# To start the micro-service locally using the test routes run the following command: "sbt run -Dapplication.router=testOnlyDoNotUseInAppConf.Routes"

# Any test-only end-point should be defined here.
# !!!WARNING!!! Every route defined in this file MUST be prefixed with "/test-only/".
# Failing to follow this rule may result in test routes deployed in production.

# Add all the application routes to the prod.routes file
->         /                          prod.Routes
#GET        /agent-registration-risking/test-only/create-application-for-risking/:numberOfIndividuals    uk.gov.hmrc.agentregistrationrisking.testOnly.controllers.TestRiskingController.createTestApplicationForRisking(numberOfIndividuals: Int)
GET        /agent-registration-risking/test-only/view-next-file-contents                              uk.gov.hmrc.agentregistrationrisking.testOnly.controllers.TestRiskingController.viewNextRiskingFileContents
GET        /agent-registration-risking/test-only/run-risking                                          uk.gov.hmrc.agentregistrationrisking.testOnly.controllers.TestRiskingController.runRisking

GET        /files-available/list/:informationType                                                     uk.gov.hmrc.agentregistrationrisking.testOnly.controllers.SdesTestOnlyController.listAvailableFiles(informationType: String)
POST       /notification/fileready                                                                    uk.gov.hmrc.agentregistrationrisking.testOnly.controllers.SdesTestOnlyController.notificationFileReady()
GET        /agent-registration-risking/test-only/risking-results-file/:filename                       uk.gov.hmrc.agentregistrationrisking.testOnly.controllers.SdesTestOnlyController.downloadRiskingResultsFile(filename: RiskingResultsFileName)
POST       /agent-registration-risking/test-only/risking-results-file/:filename                       uk.gov.hmrc.agentregistrationrisking.testOnly.controllers.SdesTestOnlyController.uploadRiskingResultsFile(filename: RiskingResultsFileName)
DELETE     /agent-registration-risking/test-only/risking-results-file/:filename                       uk.gov.hmrc.agentregistrationrisking.testOnly.controllers.SdesTestOnlyController.deleteRiskingResultsFile(filename: RiskingResultsFileName)
POST       /agent-registration-risking/test-only/delete-all-risking-results-files                     uk.gov.hmrc.agentregistrationrisking.testOnly.controllers.SdesTestOnlyController.deleteAllRiskingResultsFiles()
GET        /agent-registration-risking/test-only/run-results-file-processing                          uk.gov.hmrc.agentregistrationrisking.testOnly.controllers.SdesTestOnlyController.runResultsFileProcessingJob()

DELETE     /agent-registration-risking/test-only/applications                                         uk.gov.hmrc.agentregistrationrisking.testOnly.controllers.TestRiskingController.deleteAllApplications

GET        /agent-registration-risking/test-only/application-for-risking/:applicationReference        uk.gov.hmrc.agentregistrationrisking.testOnly.controllers.TestRiskingController.findApplicationForRisking(applicationReference: ApplicationReference)
GET        /agent-registration-risking/test-only/application-for-risking/:applicationReference        uk.gov.hmrc.agentregistrationrisking.testOnly.controllers.TestRiskingController.findIndividualsForRisking(applicationReference: ApplicationReference)