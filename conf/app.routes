# microservice specific routes

POST        /submit-for-risking                                          uk.gov.hmrc.agentregistrationrisking.controllers.SubmitForRiskingController.submitForRisking()
GET         /risking-progress/for-applicant/:applicationReference        uk.gov.hmrc.agentregistrationrisking.controllers.RiskingProgressController.getRiskingProgressForApplicant(applicationReference: ApplicationReference)
GET         /risking-progress/for-individual/:personReference            uk.gov.hmrc.agentregistrationrisking.controllers.RiskingProgressController.getRiskingProgressForIndividual(personReference: PersonReference)

POST        /receive-sdes-notifications                                  uk.gov.hmrc.agentregistrationrisking.controllers.SdesNotificationController.receiveSdesNotification
